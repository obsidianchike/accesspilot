# ════════════════════════════════════════════════
# AccessPilot Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ════════════════════════════════════════════════

# ── AI Provider ──────────────────────────────────
# Switch between 'azure' and 'openai' with one line
# Use 'azure' when your quota is approved
# Use 'openai' as a fallback (platform.openai.com)
AI_PROVIDER=azure

# ── Azure OpenAI (when AI_PROVIDER=azure) ────────
AZURE_OPENAI_ENDPOINT=https://accesspilot-foundry.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── OpenAI Direct (when AI_PROVIDER=openai) ──────
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Express Server ────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend URL (for CORS) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── Puppeteer ────────────────────────────────────
# Set to 'true' on Azure App Service (no display available)
PUPPETEER_NO_SANDBOX=false
